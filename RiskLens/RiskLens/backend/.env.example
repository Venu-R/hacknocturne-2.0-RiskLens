# Flask
SECRET_KEY=your-flask-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
PORT=5000
HOST=0.0.0.0
FLASK_DEBUG=0

# Database (PostgreSQL - Supabase/Neon/Railway)
DATABASE_URL=postgresql://username:password@host:port/database

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://your-backend.onrender.com/api/auth/github/callback

# Jira/Atlassian OAuth
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
JIRA_REDIRECT_URI=https://your-backend.onrender.com/auth/callback/jira
JIRA_OAUTH_SCOPES=read:me read:account offline_access

# Frontend
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Slack (optional)
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_CHANNEL_NAME=#alerts
SLACK_ALERT_THRESHOLD=75
